{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "plugins": [
    "./node_modules/biome-one-liner-plugin/oneLiner.grit",
    "./node_modules/biome-typescript-best-practices-plugin/typescript.grit",
    "./node_modules/biome-react-best-practices-plugin/react.grit",
    "./node_modules/biome-drizzle-best-practices-plugin/drizzle.grit"
  ],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!dist", "!node_modules"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 130
  },
  "linter": {
    "domains": {
      "qwik": "none",
      "svelte": "none",
      "solid": "none",
      "turborepo": "none",
      "vue": "none",
      "project": "recommended"
    },
    "enabled": true,
    "rules": {
      "preset": "all",
      "nursery": {
        "useSortedClasses": "on",
        "noDrizzleDeleteWithoutWhere": "on",
        "noDrizzleUpdateWithoutWhere": "on",
        "noMisleadingReturnType": "on",
        "noUnusedClasses": "on",
        "noUselessTypeConversion": "on",
        "useIncludes": "on"
      },
      "correctness": {
        "noUndeclaredDependencies": "on",
        "useJsonImportAttributes": "on",
        "noNodejsModules": "off",
        "noUndeclaredVariables": {
          "level": "error",
          "options": { "checkTypes": false }
        }
      },
      "style": {
        "useBlockStatements": "off",
        "useDestructuring": "off",
        "noDefaultExport": "off",
        "noMagicNumbers": "off",
        "noTernary": "off",
        "useNamingConvention": {
          "level": "on",
          "options": {
            "strictCase": false
          }
        },
        "useConsistentTypeDefinitions": {
          "level": "on",
          "options": {
            "style": "type"
          }
        }
      },
      "suspicious": {
        "noDeprecatedImports": "on",
        "noConsole": "off"
      }
    },
    "includes": ["**", "!dist", "!node_modules"]
  },
  "javascript": {
    "globals": ["Bun", "__DEV__"],
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
