{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "plugins": ["./node_modules/biome-one-liner-plugin/oneLiner.grit"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!!**/dist"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 130
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "all",
      "correctness": {
        "noNodejsModules": "off"
      },
      "style": {
        "useBlockStatements": "off",
        "useDestructuring": "off"
      },
      "suspicious": {
        "noConsole": "off"
      }
    },
    "includes": ["**", "!dist/**", "!node_modules/**"]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
