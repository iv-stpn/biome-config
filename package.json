{
  "name": "@iv-stpn/biome-config",
  "version": "1.2.3",
  "description": "Personal reusable Biome configuration for iv-stpn",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iv-stpn/biome-config.git"
  },
  "bugs": {
    "url": "https://github.com/iv-stpn/biome-config/issues"
  },
  "homepage": "https://github.com/iv-stpn/biome-config#readme",
  "files": [
    "biome.json",
    "README.md"
  ],
  "exports": {
    "./biome": "./biome.json"
  },
  "publishConfig": {
