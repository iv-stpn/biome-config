  },
  "peerDependencies": {
    "@biomejs/biome": "2.5.2",
    "biome-one-liner-plugin": "1.3.2",
    "biome-typescript-best-practices-plugin": "1.0.0",
    "biome-react-best-practices-plugin": "1.0.0",
    "biome-drizzle-best-practices-plugin": "1.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0"
  }
}
